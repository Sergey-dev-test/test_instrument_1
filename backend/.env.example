# Application
APP_NAME=DB Manager
APP_VERSION=1.0.0
DEBUG=False

# Server
HOST=0.0.0.0
PORT=8000

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/db_manager

# Redis
REDIS_URL=redis://localhost:6379/0

# JWT
SECRET_KEY=change-this-to-a-random-secret-key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Logging
LOG_LEVEL=INFO

# AI
AI_TIMEOUT=30
AI_MAX_TOKENS=4000
